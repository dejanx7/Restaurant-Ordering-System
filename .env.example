# Database connection string
# Start local PostgreSQL: npx prisma dev --detach
# Then use the TCP URL shown in output
DATABASE_URL="postgres://postgres:postgres@localhost:PORT/template1?sslmode=disable"

# Prisma dev proxy URL for migrations (shown in `npx prisma dev ls` output)
MIGRATE_DATABASE_URL="prisma+postgres://localhost:PORT/?api_key=..."

# Stripe (get test keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Base URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
